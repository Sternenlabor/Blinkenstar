{
  "name": "blinkenstar-manual",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Markdown source and PDF generator for the Blinkenstar manual.",
  "scripts": {
    "generate:pdf": "node scripts/markdown-to-pdf.mjs manual.md manual.generated.pdf",
    "generate:pdf:ohne-smd": "node scripts/markdown-to-pdf.mjs manual-ohne-smd.md manual-ohne-smd.generated.pdf",
    "build": "npm run generate:pdf && npm run generate:pdf:ohne-smd",
    "test": "node --test"
  },
  "dependencies": {
    "@fontsource/carlito": "^5.2.8",
    "@pdf-lib/fontkit": "^1.1.1",
    "pdf-lib": "1.17.1"
  }
}
